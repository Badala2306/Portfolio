# Get this key for free (no login) at https://web3forms.com — enter your
# email, they send you an access key instantly. Paste it below.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-access-key-here

# Optional but recommended for the GitHub stats section.
# Keep this server-side only; do not prefix it with NEXT_PUBLIC_.
GITHUB_TOKEN=your-github-token-here
